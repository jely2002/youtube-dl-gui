{
  "name": "open-video-downloader",
  "version": "3.2.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jely2002/youtube-dl-gui.git"
  },
  "scripts": {
    "dev": "cross-env DEV=true vite",
    "build": "npm run build:app && npm run build:isolation",
    "build:app": "vue-tsc --noEmit && vite build",
    "build:isolation": "vue-tsc --noEmit && vite build --config vite.config.isolation.ts",
    "tauri": "tauri",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "rust:clippy": "cargo clippy --manifest-path=src-tauri/Cargo.toml --all-features --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --manifest-path=src-tauri/Cargo.toml --all",
    "rust:lint": "npm run rust:fmt && npm run rust:clippy",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "manifest:gen": "node scripts/gen-manifest.ts",
    "manifest:sign": "node scripts/sign-manifest.ts",
    "manifest:verify": "node scripts/verify-manifest.ts",
    "manifest:fetch": "node scripts/fetch-sources.ts",
    "licenses:npm": "license-checker-rseidelsohn --production --json --out licenses/licenses-npm.json",
    "licenses:rust": "cargo about generate --manifest-path=src-tauri/Cargo.toml --output-file licenses/licenses-rust.txt src-tauri/about.hbs",
    "licenses:gen": "node scripts/licenses.ts",
    "licenses": "npm run licenses:npm && npm run licenses:rust && npm run licenses:gen"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@sentry/vue": "^10.45.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "autoprefixer": "^10.4.27",
    "iso-639-1": "^3.1.5",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "uuid": "^14.0.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@playwright/test": "1.58.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "2.4.6",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "monocart-coverage-reports": "^2.12.9",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "unzipper": "^0.12.3",
    "vite": "^8.0.5",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "vite-plugin-vue-devtools": {
      "vite-plugin-inspect": "^11.3.3"
    }
  }
}
